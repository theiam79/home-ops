---
machine:
  type: controlplane
  install:
    diskSelector:
      serial: "IB25ZD0256P00073"
  network:
    hostname: dvergar-00
    interfaces:
      - interface: mgmt0
        dhcp: false
        addresses:
          - 192.168.100.20/24
        routes:
          - network: 0.0.0.0/0
            gateway: 192.168.100.1
        mtu: 1500
        vip:
          ip: 192.168.100.5
        vlans:
          - vlanId: 70
            dhcp: false
      - interface: ceph0
        dhcp: false
        mtu: 9000
        addresses:
          - 10.10.10.20/24
  nodeLabels:
    clusterrole: highspeed
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: mgmt0
selector:
  match: mac(link.permanent_addr) == "c0:25:a5:98:c0:f6"
