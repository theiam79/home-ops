---
machine:
  type: worker
  install:
    diskSelector:
      model: Micron_7300*
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: dvergar-03
---
apiVersion: v1alpha1
kind: LinkConfig
mtu: 1500
name: mgmt0
addresses:
  - address: 192.168.100.23/24
routes:
  - gateway: 192.168.100.1
---
apiVersion: v1alpha1
kind: LinkConfig
mtu: 9000
name: ceph0
addresses:
  - address: 10.10.10.23/24
---
apiVersion: v1alpha1
kind: VLANConfig
name: mgmt0.70
parent: mgmt0
vlanID: 70
---
apiVersion: v1alpha1
kind: VLANConfig
name: mgmt0.30
parent: mgmt0
vlanID: 30
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: mgmt0
selector:
  match: mac(link.permanent_addr) == "d8:9e:f3:9a:f8:4d"
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: ceph0
selector:
  match: link.driver == "igc" && mac(link.permanent_addr).startsWith("02:26:26:02:0d:")
