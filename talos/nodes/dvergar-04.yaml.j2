---
machine:
  type: worker
  install:
    diskSelector:
      model: KINGSTON*
---
apiVersion: v1alpha1
kind: HostnameConfig
auto: "off"
hostname: dvergar-04
---
apiVersion: v1alpha1
kind: LinkConfig
mtu: 1500
name: mgmt0
addresses:
  - address: 192.168.100.24/24
routes:
  - gateway: 192.168.100.1
---
apiVersion: v1alpha1
kind: VLANConfig
name: mgmt0.70
parent: mgmt0
vlanID: 70
---
apiVersion: v1alpha1
kind: VLANConfig
name: mgmt0.30
parent: mgmt0
vlanID: 30
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: mgmt0
selector:
  match: mac(link.permanent_addr) == "48:4d:7e:d8:83:c8"
